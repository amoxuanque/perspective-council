{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://perspective-council.local/schemas/source-ledger.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": 1 },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "url", "type", "dimensions"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "pattern": "^https://" },
          "type": { "enum": ["primary", "secondary"] },
          "dimensions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["writings", "conversations", "expression", "external", "decisions", "timeline"] }
          }
        }
      }
    }
  }
}
